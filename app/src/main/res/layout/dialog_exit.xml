<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp">

        <View
            android:id="@+id/icon_container"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_circle_emerald_light"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:contentDescription="Exit Icon"
            app:tint="#1B4332"
            app:layout_constraintBottom_toBottomOf="@id/icon_container"
            app:layout_constraintEnd_toEndOf="@id/icon_container"
            app:layout_constraintStart_toStartOf="@id/icon_container"
            app:layout_constraintTop_toTopOf="@id/icon_container" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Konfirmasi Keluar"
            android:textColor="#1B4332"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/icon_container" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Masukkan kode exit yang diberikan pengawas untuk mengakhiri sesi ujian."
            android:textColor="#708D81"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <TextView
            android:id="@+id/tvInputLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="KODE EXIT"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#2D6A4F"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDescription" />

        <EditText
            android:id="@+id/etExitCode"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="#EDF2F0"
            android:hint="Masukkan kode verifikasi"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="#1B4332"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvInputLabel" />

        <LinearLayout
            android:id="@+id/action_area"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="end"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etExitCode">

            <Button
                android:id="@+id/btnCancel"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Batal"
                android:textAllCaps="false"
                android:textColor="#708D81"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnConfirmExit"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:backgroundTint="#1B4332"
                android:text="Keluar Sesi"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>