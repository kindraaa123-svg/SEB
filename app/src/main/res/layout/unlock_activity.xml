<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F1"> <View
    android:id="@+id/wave_header"
    android:layout_width="300dp"
    android:layout_height="300dp"
    android:layout_marginTop="-100dp"
    android:layout_marginEnd="-100dp"
    android:background="@android:drawable/presence_online"
    android:alpha="0.1"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:tint="#2D6A4F" />

    <View
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="120dp"
        android:alpha="0.2"
        android:background="@android:drawable/presence_online"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#52B788" />

    <LinearLayout
        android:id="@+id/login_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/card_soft_white"
        android:elevation="0dp"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keamanan"
            android:textColor="#708D81"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:letterSpacing="0.2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Buka Kunci"
            android:textColor="#1B4332"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KODE KONFIRMASI"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#2D6A4F"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etExamCode"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="32dp"
            android:background="#EDF2F0"
            android:hint="Masukkan kode buka kunci"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:textColor="#1B4332"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnDiveIn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1B4332"
            android:text="Buka Sekarang"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="4dp" />

    </LinearLayout>

    <ImageView
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="-40dp"
        android:alpha="0.05"
        android:src="@android:drawable/ic_menu_compass"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#1B4332" />

</androidx.constraintlayout.widget.ConstraintLayout>